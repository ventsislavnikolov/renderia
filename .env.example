VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Server-side mirrors of the VITE_* values (non-prefixed; not bundled to client)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
